# ==============================================================================
# WeatherFlow - Variables de Entorno
#
# Copiá este archivo a `.env` y completá los valores antes de levantar
# el stack con Docker Compose:
#
#   cp .env.example .env
#   docker-compose up --build
#
# IMPORTANTE: nunca commitees el archivo `.env` real al repositorio.
# ==============================================================================

# ------------------------------------------------------------------------------
# Phoenix — Requeridas en producción
# ------------------------------------------------------------------------------

# Clave secreta para firmar cookies y tokens. Generala con:
#   mix phx.gen.secret
SECRET_KEY_BASE=

# Hostname público donde corre la aplicación (sin protocolo ni puerto)
PHX_HOST=localhost

# Esquema HTTP del servidor público (http para desarrollo local, https para producción)
PHX_SCHEME=http

# Puerto público expuesto al exterior (4000 para docker local, 443 para producción con SSL)
PHX_PORT=4000

# Puerto interno en el que escucha Phoenix dentro del contenedor
PORT=4000

# ------------------------------------------------------------------------------
# MongoDB — Opcionales (tienen valores por defecto para desarrollo local)
# ------------------------------------------------------------------------------

# URL de conexión completa. En producción usar la URL de MongoDB Atlas u otro servicio.
# Ejemplo Atlas: mongodb+srv://usuario:password@cluster.mongodb.net
MONGO_URL=mongodb://mongodb:27017

# Nombre de la base de datos
MONGO_DATABASE=weather_flow_prod

# Tamaño del pool de conexiones a MongoDB
MONGO_POOL_SIZE=10
